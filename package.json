{
  "name": "jemacs",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "description": "Emacs-like editor kernel in TypeScript with first-class OpenTUI (terminal) and Electron (GUI) frontends.",
  "scripts": {
    "dev": "bun run src/main.ts",
    "dev:gui": "bun run scripts/build-electron.ts && npx electron dist/electron/bootstrap.mjs",
    "smoke:gui": "bun run scripts/build-electron.ts && npx electron dist/electron/bootstrap.mjs --smoke-gui",
    "preview:gui": "bun run scripts/serve-gui-preview.ts",
    "dev:self": "bun run src/main.ts src/main.ts",
    "build:gui": "bun run scripts/build-electron.ts",
    "check": "bun x tsc --noEmit",
    "test": "bun test",
    "postinstall": "node node_modules/electron/install.js && npx bun run scripts/postinstall-tree-sitter.ts",
    "generate:lsp-protocol": "bun run scripts/generate-lsp-protocol.ts",
    "start": "bun run src/main.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "@xterm/headless": "^6.0.0",
    "tree-sitter": "^0.25.0",
    "vscode-languageserver-protocol": "3.17.5",
    "vscode-languageserver-types": "3.17.5"
  },
  "optionalDependencies": {
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.2",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "electron": "^35.0.0",
    "typescript": "^5.9.0",
    "typescript-language-server": "^4.3.4"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@tree-sitter-grammars/tree-sitter-markdown",
    "tree-sitter",
    "tree-sitter-html",
    "tree-sitter-java",
    "tree-sitter-javascript",
    "tree-sitter-python"
  ]
}
