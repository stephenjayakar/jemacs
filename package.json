{
  "name": "jemacs-opentui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A tiny self-editable Emacs-like editor kernel with a JavaScript runtime and an OpenTUI frontend.",
  "scripts": {
    "dev": "bun run src/main.ts",
    "dev:self": "bun run src/main.ts src/main.ts",
    "check": "bun x tsc --noEmit",
    "test": "bun test",
    "postinstall": "bun run scripts/postinstall-tree-sitter.ts",
    "generate:lsp-protocol": "bun run scripts/generate-lsp-protocol.ts",
    "start": "bun run src/main.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "vscode-languageserver-protocol": "3.17.5",
    "vscode-languageserver-types": "3.17.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "tree-sitter",
    "tree-sitter-html",
    "tree-sitter-java",
    "tree-sitter-javascript",
    "tree-sitter-python"
  ]
}
